{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LanBeam",
  "version": "0.1.0",
  "identifier": "app.lanbeam.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LanBeam",
        "width": 1120,
        "height": 740,
        "minWidth": 920,
        "minHeight": 600,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/128x128@2x.png",
      "icons/128x128.png",
      "icons/64x64.png",
      "icons/32x32.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Johnserf-Seed",
    "copyright": "MIT © Johnserf-Seed",
    "licenseFile": "../LICENSE",
    "category": "Utility",
    "shortDescription": "LAN file transfer",
    "longDescription": "Fast, private, peer-to-peer file transfer over your local network. No cloud, no account, no relay.",
    "homepage": "https://github.com/Johnserf-Seed/lanbeam",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1"
        ]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "lanbeam"
        ]
      }
    }
  }
}
